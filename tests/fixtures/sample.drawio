<mxfile>
  <diagram name="Architecture">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ext-zone" value="External Zone" style="swimlane;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="10" y="10" width="300" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="user" value="User Browser" style="shape=ellipse;" vertex="1" parent="ext-zone">
          <mxGeometry x="50" y="50" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="int-zone" value="Internal Cloud VPC" style="swimlane;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="400" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="gw" value="API Gateway" style="shape=mxgraph.flowchart.process;" vertex="1" parent="int-zone">
          <mxGeometry x="30" y="30" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="svc1" value="User Service" style="" vertex="1" parent="int-zone">
          <mxGeometry x="30" y="130" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="svc2" value="Order Service" style="" vertex="1" parent="int-zone">
          <mxGeometry x="200" y="130" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="db" value="PostgreSQL DB" style="shape=cylinder;" vertex="1" parent="int-zone">
          <mxGeometry x="30" y="250" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="cache" value="Redis Cache" style="" vertex="1" parent="int-zone">
          <mxGeometry x="200" y="250" width="120" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="HTTPS" style="" edge="1" source="user" target="gw" parent="1"/>
        <mxCell id="e2" value="gRPC" style="" edge="1" source="gw" target="svc1" parent="1"/>
        <mxCell id="e3" value="gRPC" style="" edge="1" source="gw" target="svc2" parent="1"/>
        <mxCell id="e4" value="JDBC" style="" edge="1" source="svc1" target="db" parent="1"/>
        <mxCell id="e5" value="" style="" edge="1" source="svc2" target="db" parent="1"/>
        <mxCell id="e6" value="" style="" edge="1" source="svc1" target="cache" parent="1"/>
        <mxCell id="e7" value="HTTPS" style="" edge="1" source="svc2" target="cache" parent="1"/>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
